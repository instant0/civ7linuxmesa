--- a/src/microsoft/vulkan/dzn_descriptor_set.c
+++ b/src/microsoft/vulkan/dzn_descriptor_set.c
@@ -31,6 +31,59 @@
 
 #include "util/mesa-blake3.h"
 
+static bool
+dzn_oodm_trace_enabled(void)
+{
+   static int cached = -1;
+   if (cached < 0) {
+      const char *env = getenv("DZN_OODM_TRACE");
+      cached = (env && env[0] && strcmp(env, "0") != 0) ? 1 : 0;
+   }
+   return cached == 1;
+}
+
+static unsigned
+dzn_desc_pool_list_length(struct list_head *head)
+{
+   unsigned count = 0;
+   list_for_each_entry(struct dzn_descriptor_heap_pool_entry, entry, head, link)
+      count++;
+   return count;
+}
+
+static const char *
+dzn_desc_heap_type_name(D3D12_DESCRIPTOR_HEAP_TYPE type)
+{
+   switch (type) {
+   case D3D12_DESCRIPTOR_HEAP_TYPE_CBV_SRV_UAV: return "CBV_SRV_UAV";
+   case D3D12_DESCRIPTOR_HEAP_TYPE_SAMPLER: return "SAMPLER";
+   case D3D12_DESCRIPTOR_HEAP_TYPE_RTV: return "RTV";
+   case D3D12_DESCRIPTOR_HEAP_TYPE_DSV: return "DSV";
+   default: return "UNKNOWN";
+   }
+}
+
+static uint32_t
+dzn_cbv_srv_uav_heap_min_desc(void)
+{
+   /* Baseline for dynamic shader-visible CBV/SRV/UAV heap growth.
+    * Heavy workloads can still grow aggressively through doubling.
+    */
+   static int cached = -1;
+   if (cached < 0) {
+      uint32_t value = 2048;
+      const char *env = getenv("DZN_CBV_SRV_UAV_HEAP_MIN_DESC");
+      if (env && env[0]) {
+         char *end = NULL;
+         unsigned long parsed = strtoul(env, &end, 10);
+         if (end != env && parsed > 0 && parsed <= MAX_DESCS_PER_CBV_SRV_UAV_HEAP)
+            value = (uint32_t)parsed;
+      }
+      cached = (int)value;
+   }
+   return (uint32_t)cached;
+}
+
 static uint32_t
 translate_desc_stages(VkShaderStageFlags in)
 {
@@ -959,6 +1012,12 @@ dzn_descriptor_heap_init(struct dzn_descriptor_heap *heap,
 D3D12_CPU_DESCRIPTOR_HANDLE
 dzn_descriptor_heap_get_cpu_handle(const struct dzn_descriptor_heap *heap, uint32_t desc_offset)
 {
+   if (!heap || !heap->cpu_base || desc_offset >= heap->desc_count) {
+      return (D3D12_CPU_DESCRIPTOR_HANDLE) {
+         .ptr = 0,
+      };
+   }
+
    return (D3D12_CPU_DESCRIPTOR_HANDLE) {
       .ptr = heap->cpu_base + (desc_offset * heap->desc_sz),
    };
@@ -1932,6 +1991,26 @@ dzn_descriptor_heap_pool_alloc_slots(struct dzn_descriptor_heap_pool *pool,
       uint32_t alloc_step = ALIGN_POT(desc_count * pool->desc_sz, granularity);
       uint32_t heap_desc_count = MAX2(alloc_step / pool->desc_sz, 16);
 
+      if (pool->shader_visible &&
+          pool->type == D3D12_DESCRIPTOR_HEAP_TYPE_CBV_SRV_UAV) {
+         /* Grow dynamically to avoid overcommitting memory for light apps while
+          * still scaling fast under descriptor pressure.
+          */
+         const uint32_t base_min = dzn_cbv_srv_uav_heap_min_desc();
+         uint32_t doubled = base_min;
+
+         if (last_heap_desc_count > 0) {
+            if (last_heap_desc_count > (MAX_DESCS_PER_CBV_SRV_UAV_HEAP / 2))
+               doubled = MAX_DESCS_PER_CBV_SRV_UAV_HEAP;
+            else
+               doubled = last_heap_desc_count * 2;
+         }
+
+         heap_desc_count = MAX2(heap_desc_count, base_min);
+         heap_desc_count = MAX2(heap_desc_count, doubled);
+         heap_desc_count = MIN2(heap_desc_count, MAX_DESCS_PER_CBV_SRV_UAV_HEAP);
+      }
+
       /* Maximum of 2048 samplers per heap when shader_visible is true. */
       if (pool->shader_visible &&
           pool->type == D3D12_DESCRIPTOR_HEAP_TYPE_SAMPLER) {
@@ -1953,13 +2032,36 @@ dzn_descriptor_heap_pool_alloc_slots(struct dzn_descriptor_heap_pool *pool,
          new_heap =
             vk_zalloc(pool->alloc, sizeof(*new_heap), 8,
                       VK_SYSTEM_ALLOCATION_SCOPE_OBJECT);
-         if (!new_heap)
+         if (!new_heap) {
+            if (dzn_oodm_trace_enabled()) {
+               fprintf(stderr,
+                       "DZN_OODM[pool_alloc]: type=%s shader_visible=%u req_desc=%u "
+                       "offset=%u last_heap_desc=%u active=%u free=%u target_heap_desc=%u "
+                       "err=VK_ERROR_OUT_OF_HOST_MEMORY\n",
+                       dzn_desc_heap_type_name(pool->type), pool->shader_visible,
+                       desc_count, pool->offset, last_heap_desc_count,
+                       dzn_desc_pool_list_length(&pool->active_heaps),
+                       dzn_desc_pool_list_length(&pool->free_heaps),
+                       heap_desc_count);
+            }
             return vk_error(device, VK_ERROR_OUT_OF_HOST_MEMORY);
+         }
 
          VkResult result =
             dzn_descriptor_heap_init(&new_heap->heap, device, pool->type,
                                      heap_desc_count, pool->shader_visible);
          if (result != VK_SUCCESS) {
+            if (dzn_oodm_trace_enabled()) {
+               fprintf(stderr,
+                       "DZN_OODM[pool_alloc]: type=%s shader_visible=%u req_desc=%u "
+                       "offset=%u last_heap_desc=%u active=%u free=%u target_heap_desc=%u "
+                       "err=%d\n",
+                       dzn_desc_heap_type_name(pool->type), pool->shader_visible,
+                       desc_count, pool->offset, last_heap_desc_count,
+                       dzn_desc_pool_list_length(&pool->active_heaps),
+                       dzn_desc_pool_list_length(&pool->free_heaps),
+                       heap_desc_count, result);
+            }
             vk_free(&device->vk.alloc, new_heap);
             return result;
          }
