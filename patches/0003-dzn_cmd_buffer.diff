+static bool
+dzn_oodm_trace_enabled(void)
+{
+   static int cached = -1;
+   if (cached < 0) {
+      const char *env = getenv("DZN_OODM_TRACE");
+      cached = (env && env[0] && strcmp(env, "0") != 0) ? 1 : 0;
+   }
+   return cached == 1;
+}
+
+static unsigned
+dzn_desc_pool_list_length(struct list_head *head)
+{
+   unsigned count = 0;
+   list_for_each_entry(struct dzn_descriptor_heap_pool_entry, entry, head, link)
+      count++;
+   return count;
+}
+
+static void
+dzn_log_cmdbuf_error(struct dzn_cmd_buffer *cmdbuf, const char *where, VkResult err)
+{
+   if (!dzn_oodm_trace_enabled())
+      return;
+
+   fprintf(stderr,
+           "DZN_OODM[%s]: err=%d cmdbuf=%p "
+           "rtv_entries=%u dsv_entries=%u "
+           "rtv_off=%u dsv_off=%u cbv_off=%u samp_off=%u "
+           "rtv_active=%u dsv_active=%u cbv_active=%u samp_active=%u\n",
+           where, err, (void *)cmdbuf,
+           cmdbuf->rtvs.ht ? _mesa_hash_table_num_entries(cmdbuf->rtvs.ht) : 0,
+           cmdbuf->dsvs.ht ? _mesa_hash_table_num_entries(cmdbuf->dsvs.ht) : 0,
+           cmdbuf->rtvs.pool.offset, cmdbuf->dsvs.pool.offset,
+           cmdbuf->cbv_srv_uav_pool.offset, cmdbuf->sampler_pool.offset,
+           dzn_desc_pool_list_length(&cmdbuf->rtvs.pool.active_heaps),
+           dzn_desc_pool_list_length(&cmdbuf->dsvs.pool.active_heaps),
+           dzn_desc_pool_list_length(&cmdbuf->cbv_srv_uav_pool.active_heaps),
+           dzn_desc_pool_list_length(&cmdbuf->sampler_pool.active_heaps));
+}
