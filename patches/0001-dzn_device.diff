+static bool
+dzn_contract_log_enabled(void)
+{
+   static int enabled = -1;
+   if (enabled < 0) {
+      const char *opt = os_get_option("DZN_CONTRACT_LOG");
+      enabled = (opt && opt[0] && strcmp(opt, "0") != 0) ? 1 : 0;
+   }
+   return enabled == 1;
+}
+
+static bool
+dzn_experimental_dual_src_blend_enabled(void)
+{
+   return debug_get_bool_option("DZN_EXPERIMENTAL_DUAL_SRC_BLEND", false);
+}
+
+static void
+dzn_contract_log_extensions(const char *scope, uint32_t count, const char *const *names)
+{
+   if (!dzn_contract_log_enabled())
+      return;
+
+   fprintf(stderr, "DZN_CONTRACT[%s]: extension_count=%u\n", scope, count);
+   for (uint32_t i = 0; i < count; i++)
+      fprintf(stderr, "DZN_CONTRACT[%s]: ext[%u]=%s\n", scope, i, names[i]);
+}
+
+static void
+dzn_contract_log_instance_create_info(const VkInstanceCreateInfo *info)
+{
+   if (!dzn_contract_log_enabled())
+      return;
+
+   fprintf(stderr, "DZN_CONTRACT[instance]: apiVersion=0x%x app=%s engine=%s\n",
+           info->pApplicationInfo ? info->pApplicationInfo->apiVersion : 0,
+           (info->pApplicationInfo && info->pApplicationInfo->pApplicationName) ?
+           info->pApplicationInfo->pApplicationName : "(null)",
+           (info->pApplicationInfo && info->pApplicationInfo->pEngineName) ?
+           info->pApplicationInfo->pEngineName : "(null)");
+   dzn_contract_log_extensions("instance", info->enabledExtensionCount, info->ppEnabledExtensionNames);
+}
+
+static void
+dzn_contract_log_features2(const VkPhysicalDeviceFeatures2 *f2)
+{
+   fprintf(stderr,
+           "DZN_CONTRACT[device]: features2 core: dualSrcBlend=%d samplerAnisotropy=%d imageCubeArray=%d shaderInt64=%d\n",
+           f2->features.dualSrcBlend,
+           f2->features.samplerAnisotropy,
+           f2->features.imageCubeArray,
+           f2->features.shaderInt64);
+}
+
+static void
+dzn_contract_log_device_feature_chain(const VkDeviceCreateInfo *info)
+{
+   if (!dzn_contract_log_enabled())
+      return;
+
+   if (info->pEnabledFeatures) {
+      const VkPhysicalDeviceFeatures *f = info->pEnabledFeatures;
+      fprintf(stderr,
+              "DZN_CONTRACT[device]: enabledFeatures legacy: dualSrcBlend=%d samplerAnisotropy=%d imageCubeArray=%d shaderInt64=%d\n",
+              f->dualSrcBlend, f->samplerAnisotropy, f->imageCubeArray, f->shaderInt64);
+   }
+
+   const VkBaseInStructure *ext = (const VkBaseInStructure *)info->pNext;
+   while (ext) {
+      switch (ext->sType) {
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_FEATURES_2: {
+         dzn_contract_log_features2((const VkPhysicalDeviceFeatures2 *)ext);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VULKAN_1_1_FEATURES: {
+         const VkPhysicalDeviceVulkan11Features *f = (const VkPhysicalDeviceVulkan11Features *)ext;
+         fprintf(stderr,
+                 "DZN_CONTRACT[device]: vulkan11: multiview=%d variablePointers=%d\n",
+                 f->multiview, f->variablePointers);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VULKAN_1_2_FEATURES: {
+         const VkPhysicalDeviceVulkan12Features *f = (const VkPhysicalDeviceVulkan12Features *)ext;
+         fprintf(stderr,
+                 "DZN_CONTRACT[device]: vulkan12: descriptorIndexing=%d bufferDeviceAddress=%d timelineSemaphore=%d shaderFloat16=%d\n",
+                 f->descriptorIndexing, f->bufferDeviceAddress, f->timelineSemaphore, f->shaderFloat16);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VULKAN_1_3_FEATURES: {
+         const VkPhysicalDeviceVulkan13Features *f = (const VkPhysicalDeviceVulkan13Features *)ext;
+         fprintf(stderr,
+                 "DZN_CONTRACT[device]: vulkan13: dynamicRendering=%d synchronization2=%d\n",
+                 f->dynamicRendering, f->synchronization2);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_DESCRIPTOR_INDEXING_FEATURES: {
+         const VkPhysicalDeviceDescriptorIndexingFeatures *f =
+            (const VkPhysicalDeviceDescriptorIndexingFeatures *)ext;
+         fprintf(stderr,
+                 "DZN_CONTRACT[device]: descriptorIndexingEXT: runtimeDescriptorArray=%d descriptorBindingPartiallyBound=%d\n",
+                 f->runtimeDescriptorArray, f->descriptorBindingPartiallyBound);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_BUFFER_DEVICE_ADDRESS_FEATURES: {
+         const VkPhysicalDeviceBufferDeviceAddressFeatures *f =
+            (const VkPhysicalDeviceBufferDeviceAddressFeatures *)ext;
+         fprintf(stderr,
+                 "DZN_CONTRACT[device]: bufferDeviceAddressEXT: bufferDeviceAddress=%d captureReplay=%d\n",
+                 f->bufferDeviceAddress, f->bufferDeviceAddressCaptureReplay);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_DYNAMIC_RENDERING_FEATURES: {
+         const VkPhysicalDeviceDynamicRenderingFeatures *f =
+            (const VkPhysicalDeviceDynamicRenderingFeatures *)ext;
+         fprintf(stderr, "DZN_CONTRACT[device]: dynamicRenderingKHR=%d\n", f->dynamicRendering);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_TIMELINE_SEMAPHORE_FEATURES: {
+         const VkPhysicalDeviceTimelineSemaphoreFeatures *f =
+            (const VkPhysicalDeviceTimelineSemaphoreFeatures *)ext;
+         fprintf(stderr, "DZN_CONTRACT[device]: timelineSemaphoreKHR=%d\n", f->timelineSemaphore);
+         break;
+      }
+      case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_SYNCHRONIZATION_2_FEATURES: {
+         const VkPhysicalDeviceSynchronization2Features *f =
+            (const VkPhysicalDeviceSynchronization2Features *)ext;
+         fprintf(stderr, "DZN_CONTRACT[device]: synchronization2KHR=%d\n", f->synchronization2);
+         break;
+      }
+      default:
+         fprintf(stderr, "DZN_CONTRACT[device]: pNext sType=%u\n", ext->sType);
+         break;
+      }
+
+      ext = ext->pNext;
+   }
+}
+
+static void
+dzn_contract_log_device_create_info(const VkDeviceCreateInfo *info)
+{
+   if (!dzn_contract_log_enabled())
+      return;
+
+   fprintf(stderr, "DZN_CONTRACT[device]: queueCreateInfoCount=%u enabledLayerCount=%u\n",
+           info->queueCreateInfoCount, info->enabledLayerCount);
+   dzn_contract_log_extensions("device", info->enabledExtensionCount, info->ppEnabledExtensionNames);
+   dzn_contract_log_device_feature_chain(info);
+}
